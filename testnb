0, features=9)\n  X_val   : (364, 60, 9)\n  X_test  : (364, 60, 9)\n  y_train : (1698, 1)\n  y_val   : (364, 1)\n  y_test  : (364, 1)\n\n  Batch size : 64\n  Features   : ['Open', 'High', 'Low', 'Close', 'Volume', 'MA_10', 'MA_30', 'Return', 'Volatility']\n  Target     : Close (index 3)\n\nThis (samples, seq_len, features) shape is the universal input format for both Transformer and LSTM in Keras.\n","output_type":"stream"}],"execution_count":48},{"id":"t9-code","cell_type":"code","source":"# ── Transformer Step 9: Positional Encoding ────────────────────────────────────\ndef get_positional_encoding(seq_len, d_model):\n    \"\"\"\n    Sinusoidal positional encoding.\n    Returns tensor of shape (1, seq_len, d_model) — broadcastable over batch.\n    \"\"\"\n    positions = np.arange(seq_len)[:, np.newaxis]                   # (seq_len, 1)\n    dims      = np.arange(d_model)[np.newaxis, :]                   # (1, d_model)\n    angle_rads = positions / np.power(\n        10000.0, (2 * (dims // 2)) / np.float32(d_model)\n    )\n    # sin → even indices;  cos → odd indices\n    angle_rads[:, 0::2] = np.sin(angle_rads[:, 0::2])\n    angle_rads[:, 1::2] = np.cos(angle_rads[:, 1::2])\n\n    pos_enc = angle_rads[np.newaxis, :, :]                          # (1, seq_len, d_model)\n    return tf.cast(pos_enc, dtype=tf.float32)\n\n# ── Visualise ───────────────────────────────────────────────────────────────────\nD_MODEL  = 64\npos_enc_vis = get_positional_encoding(SEQ_LEN, D_MODEL)\n\nfig, axes = plt.subplots(1, 2, figsize=(15, 4))\n\nim = axes[0].imshow(pos_enc_vis[0].numpy().T, aspect='auto',\n                    cmap='RdBu', origin='lower')\naxes[0].set_title(f'Sinusoidal Positional Encoding Matrix\\n(d_model={D_MODEL}, seq_len={SEQ_LEN})')\naxes[0].set_xlabel('Position (Time Step)')\naxes[0].set_ylabel('Encoding Dimension')\nplt.colorbar(im, ax=axes[0])\n\n# Show a few encoding dimensions over time\nfor dim in [0, 1, 4, 8, 16]:\n    axes[1].plot(pos_enc_vis[0, :, dim].numpy(),\n                 label=f'dim {dim}', linewidth=1.4)\naxes[1].set_title('Positional Encoding — Selected Dimensions vs Time Step')\naxes[1].set_xlabel('Time Step (position)')\naxes[1].set_ylabel('Encoding Value')\naxes[1].legend(fontsize=9)\naxes[1].grid(True, alpha=0.3)\n\nplt.tight_layout()\nplt.show()\nprint('Each time step receives a unique sinusoidal fingerprint — preserving order.')\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-23T05:02:41.091932Z","iopub.execute_input":"2026-04-23T05:02:41.092658Z","iopub.status.idle":"2026-04-23T05:02:41.540649Z","shell.execute_reply.started":"2026-04-23T05:02:41.092627Z","shell.execute_reply":"2026-04-23T05:02:41.539968Z"}},"outputs":[{"output_type":"display_data","data":{"text/plain":"<Figure size 1800x480 with 3 Axes>","image/png":"\n"},"metadata":{}},{"name":"stdout","text":"Each time step receives a unique sinusoidal fingerprint — preserving order.\n","output_type":"stream"}],"execution_count":50},{"id":"t10-hdr","cell_type":"markdown","source":"## Transformer Step 10 — Define Transformer Architecture\n\n```\nInput (batch, 60, 5)\n  │\n  ├─ Linear Projection → d_model=64\n  ├─ + Positional Encoding\n  ├─ Dropout\n  │\n  ├─ TransformerBlock × 2\n  │     ├─ Multi-Head Self-Attention (4 heads)\n  │     ├─ Add & LayerNorm\n  │     ├─ Feed-Forward Network (ReLU, d_ff=128)\n  │     └─ Add & LayerNorm\n  │\n  ├─ GlobalAveragePooling1D\n  ├─ Dense(64, relu) → Dropout\n  ├─ Dense(32, relu)\n  └─ Dense(1)  ← predicted Close price\n```","metadata":{}},{"id":"t10-code","cell_type":"code","source":"# ── Transformer Step 10: Define Architecture ────────────────────────────────────\n\nclass TransformerBlock(layers.Layer):\n    \"\"\"\n    Single Transformer Encoder Block:\n      Multi-Head Self-Attention  →  Add & LayerNorm\n      Feed-Forward Network       →  Add & LayerNorm\n    \"\"\"\n    def __init__(self, d_model, num_heads, ff_dim, dropout_rate=0.1, **kwargs):\n        super().__init__(**kwargs)\n        self.d_model       = d_model\n        self.num_heads     = num_heads\n        self.ff_dim        = ff_dim\n        self.dropout_rate  = dropout_rate\n\n        # Multi-Head Self-Attention\n        self.mha = layers.MultiHeadAttention(\n            num_heads=num_heads,\n            key_dim=d_model // num_heads,\n            dropout=dropout_rate\n        )\n        # Position-wise Feed-Forward Network\n        self.ffn = keras.Sequential([\n            layers.Dense(ff_dim, activation='relu'),\n            layers.Dropout(dropout_rate),\n            layers.Dense(d_model)\n        ])\n        # Layer Normalisation\n        self.layernorm1 = layers.LayerNormalization(epsilon=1e-6)\n        self.layernorm2 = layers.LayerNormalization(epsilon=1e-6)\n        self.dropout1   = layers.Dropout(dropout_rate)\n        self.dropout2   = layers.Dropout(dropout_rate)\n\n    def call(self, inputs, training=False):\n        # ── Sub-layer 1: Multi-Head Self-Attention ──────────────────────────────\n        attn_out = self.mha(inputs, inputs, training=training)\n        attn_out = self.dropout1(attn_out, training=training)\n        out1     = self.layernorm1(inputs + attn_out)\n\n        # ── Sub-layer 2: Feed-Forward Network ──────────────────────────────────\n        ffn_out = self.ffn(out1, training=training)\n        ffn_out = self.dropout2(ffn_out, training=training)\n        return  self.layernorm2(out1 + ffn_out)\n\n    def get_config(self):\n        cfg = super().get_config()\n        cfg.update({'d_model': self.d_model, 'num_heads': self.num_heads,\n                    'ff_dim': self.ff_dim, 'dropout_rate': self.dropout_rate})\n        return cfg\n\n\ndef build_transformer(seq_len, n_features,\n                       d_model=128, num_heads=8, ff_dim=256,\n                       num_blocks=3, dropout_rate=0.1):\n    \"\"\"\n    Full Transformer encoder for time-series forecasting.\n    d_model=128, heads=8, ff_dim=256, blocks=3 — upgraded from original.\n    Last-timestep slice replaces GlobalAveragePooling1D for recency bias.\n    \"\"\"\n    inp = keras.Input(shape=(seq_len, n_features), name='input')\n\n    # ── Project to d_model dimensions ───────────────────────────────────────────\n    x = layers.Dense(d_model, name='input_projection')(inp)\n\n    # ── Add positional encoding ──────────────────────────────────────────────────\n    x = x + get_positional_encoding(seq_len, d_model)\n    x = layers.Dropout(dropout_rate, name='pos_dropout')(x)\n\n    # ── Stack Transformer Blocks ──────────────────────────────────────────────────\n    for i in range(num_blocks):\n        x = TransformerBlock(\n            d_model, num_heads, ff_dim, dropout_rate,\n            name=f'transformer_block_{i+1}'\n        )(x)\n\n    # ── Use last timestep only (has attended over full sequence) ─────────────────\n    # GlobalAveragePooling1D averaged ALL timesteps equally — wrong for forecasting\n    # because the most recent timestep carries the strongest predictive signal.\n    x = x[:, -1, :]   # shape: (batch, d_model)\n\n    # ── Regression head ──────────────────────────────────────────────────────────\n    x = layers.Dense(64, activation='relu', name='dense_1')(x)\n    x = layers.Dropout(dropout_rate, name='head_dropout')(x)\n    x = layers.Dense(32, activation='relu', name='dense_2')(x)\n    out = layers.Dense(1, name='output')(x)\n\n    return keras.Model(inp, out, name='Transformer_Forecaster')\n\n\n# ── Hyperparameters ──────────────────────────────────────────────────────────────\nT_D_MODEL    = 128   # increased from 64\nT_NUM_HEADS  = 8     # increased from 4\nT_FF_DIM     = 256   # increased from 128\nT_NUM_BLOCKS = 3     # increased from 2\nT_DROPOUT    = 0.1\n\ntransformer_model = build_transformer(\n    seq_len=SEQ, n_features=N_FEATURES,\n    d_model=T_D_MODEL, num_heads=T_NUM_HEADS,\n    ff_dim=T_FF_DIM, num_blocks=T_NUM_BLOCKS,\n    dropout_rate=T_DROPOUT\n)\ntransformer_model.summary()","metadata":{"trusted":true,"execution":{"iop